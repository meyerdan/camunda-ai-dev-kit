<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
                  id="Definitions_1"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="Camunda Modeler"
                  exporterVersion="5.32.0"
                  modeler:executionPlatform="Camunda Cloud"
                  modeler:executionPlatformVersion="8.9.0">

  <bpmn:process id="hiring-pipeline" name="Hiring Pipeline" isExecutable="true">

    <!-- Start Event -->
    <bpmn:startEvent id="StartEvent_1" name="Application Received">
      <bpmn:outgoing>Flow_start_to_screening</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Resume Screening (Business Rule Task / DMN) -->
    <bpmn:businessRuleTask id="Activity_resume_screening" name="Screen Resume">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="resume-screening" resultVariable="qualified"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_start_to_screening</bpmn:incoming>
      <bpmn:outgoing>Flow_screening_to_gw_qualified</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <!-- Gateway: Qualified? -->
    <bpmn:exclusiveGateway id="Gateway_qualified" name="Qualified?">
      <bpmn:incoming>Flow_screening_to_gw_qualified</bpmn:incoming>
      <bpmn:outgoing>Flow_qualified_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_qualified_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Send Rejection (screening failed) -->
    <bpmn:serviceTask id="Activity_send_rejection_screening" name="Send Rejection">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-rejection" retries="3"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_qualified_no</bpmn:incoming>
      <bpmn:outgoing>Flow_rejection_screening_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End: Candidate Rejected (screening) -->
    <bpmn:endEvent id="EndEvent_rejected_screening" name="Candidate Rejected">
      <bpmn:incoming>Flow_rejection_screening_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Call Activity: Interview Process -->
    <bpmn:callActivity id="Activity_interview_process" name="Interview Process">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="interview-process" propagateAllChildVariables="false"/>
        <zeebe:ioMapping>
          <zeebe:input source="=candidateName" target="candidateName"/>
          <zeebe:input source="=position" target="position"/>
          <zeebe:output source="=interviewScore" target="interviewScore"/>
          <zeebe:output source="=interviewFeedback" target="interviewFeedback"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_qualified_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_interview_to_decision</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary on Call Activity (interview cancellation) -->
    <bpmn:boundaryEvent id="BoundaryEvent_interview_error" name="Interview Cancelled" attachedToRef="Activity_interview_process">
      <bpmn:outgoing>Flow_interview_error_to_rejection</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_interview"/>
    </bpmn:boundaryEvent>

    <!-- Send Rejection (interview cancelled) -->
    <bpmn:serviceTask id="Activity_send_rejection_cancelled" name="Send Rejection">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-rejection" retries="3"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_interview_error_to_rejection</bpmn:incoming>
      <bpmn:outgoing>Flow_rejection_cancelled_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End: Interview Cancelled -->
    <bpmn:endEvent id="EndEvent_interview_cancelled" name="Interview Cancelled">
      <bpmn:incoming>Flow_rejection_cancelled_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Hiring Decision (User Task) -->
    <bpmn:userTask id="Activity_hiring_decision" name="Hiring Decision">
      <bpmn:extensionElements>
        <zeebe:formDefinition formId="hiring-decision-form"/>
        <zeebe:userTask/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_interview_to_decision</bpmn:incoming>
      <bpmn:outgoing>Flow_decision_to_gw_outcome</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Non-Interrupting Timer Boundary on Hiring Decision (3 day reminder) -->
    <bpmn:boundaryEvent id="BoundaryEvent_reminder" name="3 Day Reminder" cancelActivity="false" attachedToRef="Activity_hiring_decision">
      <bpmn:outgoing>Flow_reminder_to_end</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_reminder">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">="PT3D"</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- End: Reminder Sent -->
    <bpmn:endEvent id="EndEvent_reminder" name="Reminder Sent">
      <bpmn:incoming>Flow_reminder_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Gateway: Hiring Outcome -->
    <bpmn:exclusiveGateway id="Gateway_outcome" name="Decision?">
      <bpmn:incoming>Flow_decision_to_gw_outcome</bpmn:incoming>
      <bpmn:outgoing>Flow_outcome_offer</bpmn:outgoing>
      <bpmn:outgoing>Flow_outcome_reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Send Offer -->
    <bpmn:serviceTask id="Activity_send_offer" name="Send Offer">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-offer" retries="3"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_outcome_offer</bpmn:incoming>
      <bpmn:outgoing>Flow_offer_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Send Rejection (final) -->
    <bpmn:serviceTask id="Activity_send_rejection_final" name="Send Rejection">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-rejection" retries="3"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_outcome_reject</bpmn:incoming>
      <bpmn:outgoing>Flow_rejection_final_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End: Offer Sent -->
    <bpmn:endEvent id="EndEvent_offer_sent" name="Offer Sent">
      <bpmn:incoming>Flow_offer_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- End: Candidate Rejected (final) -->
    <bpmn:endEvent id="EndEvent_rejected_final" name="Candidate Rejected">
      <bpmn:incoming>Flow_rejection_final_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="Flow_start_to_screening" sourceRef="StartEvent_1" targetRef="Activity_resume_screening"/>
    <bpmn:sequenceFlow id="Flow_screening_to_gw_qualified" sourceRef="Activity_resume_screening" targetRef="Gateway_qualified"/>
    <bpmn:sequenceFlow id="Flow_qualified_yes" name="Yes (score &#62;= 70)" sourceRef="Gateway_qualified" targetRef="Activity_interview_process">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=qualified = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_qualified_no" name="No" sourceRef="Gateway_qualified" targetRef="Activity_send_rejection_screening">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=qualified = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_rejection_screening_to_end" sourceRef="Activity_send_rejection_screening" targetRef="EndEvent_rejected_screening"/>
    <bpmn:sequenceFlow id="Flow_interview_to_decision" sourceRef="Activity_interview_process" targetRef="Activity_hiring_decision"/>
    <bpmn:sequenceFlow id="Flow_interview_error_to_rejection" sourceRef="BoundaryEvent_interview_error" targetRef="Activity_send_rejection_cancelled"/>
    <bpmn:sequenceFlow id="Flow_rejection_cancelled_to_end" sourceRef="Activity_send_rejection_cancelled" targetRef="EndEvent_interview_cancelled"/>
    <bpmn:sequenceFlow id="Flow_decision_to_gw_outcome" sourceRef="Activity_hiring_decision" targetRef="Gateway_outcome"/>
    <bpmn:sequenceFlow id="Flow_reminder_to_end" sourceRef="BoundaryEvent_reminder" targetRef="EndEvent_reminder"/>
    <bpmn:sequenceFlow id="Flow_outcome_offer" name="OFFER" sourceRef="Gateway_outcome" targetRef="Activity_send_offer">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=hiringDecision = "OFFER"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_outcome_reject" name="REJECT" sourceRef="Gateway_outcome" targetRef="Activity_send_rejection_final">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=hiringDecision = "REJECT"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_offer_to_end" sourceRef="Activity_send_offer" targetRef="EndEvent_offer_sent"/>
    <bpmn:sequenceFlow id="Flow_rejection_final_to_end" sourceRef="Activity_send_rejection_final" targetRef="EndEvent_rejected_final"/>

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="hiring-pipeline">

      <!-- Start Event -->
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="180" y="290" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="159" y="333" width="78" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Resume Screening -->
      <bpmndi:BPMNShape id="Activity_resume_screening_di" bpmnElement="Activity_resume_screening">
        <dc:Bounds x="280" y="268" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- Gateway: Qualified? -->
      <bpmndi:BPMNShape id="Gateway_qualified_di" bpmnElement="Gateway_qualified" isMarkerVisible="true">
        <dc:Bounds x="445" y="283" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="445" y="259" width="50" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Send Rejection (screening) -->
      <bpmndi:BPMNShape id="Activity_send_rejection_screening_di" bpmnElement="Activity_send_rejection_screening">
        <dc:Bounds x="540" y="410" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- End: Candidate Rejected (screening) -->
      <bpmndi:BPMNShape id="EndEvent_rejected_screening_di" bpmnElement="EndEvent_rejected_screening">
        <dc:Bounds x="702" y="432" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="677" y="475" width="87" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Call Activity: Interview Process -->
      <bpmndi:BPMNShape id="Activity_interview_process_di" bpmnElement="Activity_interview_process">
        <dc:Bounds x="570" y="268" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- Error Boundary on Call Activity -->
      <bpmndi:BPMNShape id="BoundaryEvent_interview_error_di" bpmnElement="BoundaryEvent_interview_error">
        <dc:Bounds x="592" y="330" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="535" y="363" width="90" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Send Rejection (interview cancelled) -->
      <bpmndi:BPMNShape id="Activity_send_rejection_cancelled_di" bpmnElement="Activity_send_rejection_cancelled">
        <dc:Bounds x="570" y="530" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- End: Interview Cancelled -->
      <bpmndi:BPMNShape id="EndEvent_interview_cancelled_di" bpmnElement="EndEvent_interview_cancelled">
        <dc:Bounds x="732" y="552" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="706" y="595" width="90" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Hiring Decision -->
      <bpmndi:BPMNShape id="Activity_hiring_decision_di" bpmnElement="Activity_hiring_decision">
        <dc:Bounds x="740" y="268" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- Non-Interrupting Timer Boundary -->
      <bpmndi:BPMNShape id="BoundaryEvent_reminder_di" bpmnElement="BoundaryEvent_reminder">
        <dc:Bounds x="772" y="330" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="750" y="373" width="80" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- End: Reminder Sent -->
      <bpmndi:BPMNShape id="EndEvent_reminder_di" bpmnElement="EndEvent_reminder">
        <dc:Bounds x="772" y="432" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="753" y="475" width="74" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Gateway: Decision? -->
      <bpmndi:BPMNShape id="Gateway_outcome_di" bpmnElement="Gateway_outcome" isMarkerVisible="true">
        <dc:Bounds x="905" y="283" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="907" y="259" width="47" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Send Offer -->
      <bpmndi:BPMNShape id="Activity_send_offer_di" bpmnElement="Activity_send_offer">
        <dc:Bounds x="1020" y="190" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- Send Rejection (final) -->
      <bpmndi:BPMNShape id="Activity_send_rejection_final_di" bpmnElement="Activity_send_rejection_final">
        <dc:Bounds x="1020" y="350" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- End: Offer Sent -->
      <bpmndi:BPMNShape id="EndEvent_offer_sent_di" bpmnElement="EndEvent_offer_sent">
        <dc:Bounds x="1182" y="212" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1174" y="255" width="52" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- End: Candidate Rejected (final) -->
      <bpmndi:BPMNShape id="EndEvent_rejected_final_di" bpmnElement="EndEvent_rejected_final">
        <dc:Bounds x="1182" y="372" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1157" y="415" width="87" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Sequence Flow Edges -->
      <bpmndi:BPMNEdge id="Flow_start_to_screening_di" bpmnElement="Flow_start_to_screening">
        <di:waypoint x="216" y="308"/>
        <di:waypoint x="280" y="308"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_screening_to_gw_qualified_di" bpmnElement="Flow_screening_to_gw_qualified">
        <di:waypoint x="380" y="308"/>
        <di:waypoint x="445" y="308"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_qualified_yes_di" bpmnElement="Flow_qualified_yes">
        <di:waypoint x="495" y="308"/>
        <di:waypoint x="570" y="308"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="497" y="290" width="84" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_qualified_no_di" bpmnElement="Flow_qualified_no">
        <di:waypoint x="470" y="333"/>
        <di:waypoint x="470" y="450"/>
        <di:waypoint x="540" y="450"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="478" y="389" width="15" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_rejection_screening_to_end_di" bpmnElement="Flow_rejection_screening_to_end">
        <di:waypoint x="640" y="450"/>
        <di:waypoint x="702" y="450"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_interview_to_decision_di" bpmnElement="Flow_interview_to_decision">
        <di:waypoint x="670" y="308"/>
        <di:waypoint x="740" y="308"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_interview_error_to_rejection_di" bpmnElement="Flow_interview_error_to_rejection">
        <di:waypoint x="610" y="366"/>
        <di:waypoint x="610" y="530"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_rejection_cancelled_to_end_di" bpmnElement="Flow_rejection_cancelled_to_end">
        <di:waypoint x="670" y="570"/>
        <di:waypoint x="732" y="570"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_decision_to_gw_outcome_di" bpmnElement="Flow_decision_to_gw_outcome">
        <di:waypoint x="840" y="308"/>
        <di:waypoint x="905" y="308"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_reminder_to_end_di" bpmnElement="Flow_reminder_to_end">
        <di:waypoint x="790" y="366"/>
        <di:waypoint x="790" y="432"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_outcome_offer_di" bpmnElement="Flow_outcome_offer">
        <di:waypoint x="930" y="283"/>
        <di:waypoint x="930" y="230"/>
        <di:waypoint x="1020" y="230"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="950" y="213" width="38" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_outcome_reject_di" bpmnElement="Flow_outcome_reject">
        <di:waypoint x="930" y="333"/>
        <di:waypoint x="930" y="390"/>
        <di:waypoint x="1020" y="390"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="945" y="373" width="42" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_offer_to_end_di" bpmnElement="Flow_offer_to_end">
        <di:waypoint x="1120" y="230"/>
        <di:waypoint x="1182" y="230"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_rejection_final_to_end_di" bpmnElement="Flow_rejection_final_to_end">
        <di:waypoint x="1120" y="390"/>
        <di:waypoint x="1182" y="390"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
